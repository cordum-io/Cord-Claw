# CordClaw + OpenClaw Docker Stack
# ================================
#
# Copy to `.env` and populate. Variables here are consumed by both
# docker-compose.yaml and the cordclaw-daemon/openclaw-gateway containers.
#
# CORDUM_API_KEY must match the key the Cordum stack is running with.
# If you installed Cordum separately, read the running gateway's key:
#   docker inspect cordum-api-gateway-1 \
#     --format '{{range .Config.Env}}{{println .}}{{end}}' \
#     | grep '^CORDUM_API_KEY='
# and paste that value here. CordClaw's setup/install.sh auto-detects this
# when run against an existing Cordum stack; only set manually when the
# installer is not in play.

# Cordum API key — must match the running Cordum stack.
CORDUM_API_KEY=

# CordClaw policy profile: strict | moderate | permissive
CORDCLAW_PROFILE=moderate

# Cron-origin decision persistence. Keep the path under /var/lib/cordclaw so
# the daemon state volume preserves allowed cron decisions across restarts.
CORDCLAW_CRON_DECISION_STORE=bolt
CORDCLAW_CRON_DECISION_PATH=/var/lib/cordclaw/cron-decisions.db
CORDCLAW_CRON_DECISION_TTL=24h

# OpenClaw gateway auth token (local-only — rotate freely).
OPENCLAW_GATEWAY_TOKEN=

# LLM provider keys — set at least one. CordClaw uses ANTHROPIC by default.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
