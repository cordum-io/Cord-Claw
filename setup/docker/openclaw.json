{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "0210e58c67a114e7d392aeba34fadf4b40752d71c24ced7121f7165353745df2"
    },
    "controlUi": {
      "enabled": true,
      "dangerouslyDisableDeviceAuth": true,
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789"
      ]
    }
  },
  "env": {
    "OPENAI_API_KEY": "$OPENAI_API_KEY",
    "ANTHROPIC_API_KEY": "$ANTHROPIC_API_KEY"
  },
  "auth": {
    "profiles": {
      "anthropic:env": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    },
    "order": {
      "anthropic": ["anthropic:env"]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-5",
        "fallbacks": ["anthropic/claude-opus-4-5", "openai/gpt-5.2"]
      },
      "workspace": "/home/node/.openclaw/workspace"
    }
  },
  "plugins": {
    "entries": {
      "cordclaw": {
        "enabled": true,
        "config": {
          "daemonUrl": "http://cordclaw-daemon:19090",
          "timeoutMs": 500,
          "failMode": "deny",
          "logDecisions": true,
          "bypassTools": []
        }
      }
    }
  }
}
