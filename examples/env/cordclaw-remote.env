# Required
CORDCLAW_KERNEL_ADDR=your-safety-kernel-host:50051
CORDCLAW_API_KEY=replace-with-cordum-api-key
CORDCLAW_TENANT_ID=default

# Optional daemon behavior
CORDCLAW_LISTEN_ADDR=127.0.0.1:19090
CORDCLAW_FAIL_MODE=graduated
CORDCLAW_CACHE_TTL=5m
CORDCLAW_CACHE_MAX_SIZE=10000
CORDCLAW_LOG_DECISIONS=true

# Cron-origin decision persistence.
# Use BoltDB in production with a writable state directory so allowed cron jobs
# survive daemon restarts. `memory` is for local tests/dev only.
CORDCLAW_CRON_DECISION_STORE=bolt
CORDCLAW_CRON_DECISION_PATH=/var/lib/cordclaw/cron-decisions.db
CORDCLAW_CRON_DECISION_TTL=24h

# TLS configuration for remote kernel connections
CORDCLAW_KERNEL_INSECURE=false
CORDCLAW_KERNEL_TLS_CA=/absolute/path/to/ca.pem
