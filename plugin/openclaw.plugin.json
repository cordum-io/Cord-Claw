{
  "id": "cordclaw",
  "name": "CordClaw - Cordum Governance",
  "version": "0.1.0",
  "description": "Pre-dispatch governance for OpenClaw via Cordum Safety Kernel",
  "homepage": "https://github.com/cordum-io/cordclaw",
  "author": "Cordum <hello@cordum.io>",
  "license": "Apache-2.0",
  "openclaw": {
    "minVersion": "2026.3.0",
    "extensions": ["dist/index.js"],
    "plugin": {
      "configSchema": {
        "type": "object",
        "properties": {
          "daemonUrl": {
            "type": "string",
            "default": "http://127.0.0.1:19090",
            "description": "CordClaw daemon HTTP address"
          },
          "timeoutMs": {
            "type": "number",
            "default": 500,
            "description": "Max wait for daemon response (ms)"
          },
          "failMode": {
            "type": "string",
            "enum": ["deny", "allow"],
            "default": "deny",
            "description": "Behavior when daemon is unreachable"
          },
          "logDecisions": {
            "type": "boolean",
            "default": true,
            "description": "Log governance decisions to OpenClaw console"
          },
          "bypassTools": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Tool names that skip governance (use sparingly)"
          }
        }
      }
    }
  }
}